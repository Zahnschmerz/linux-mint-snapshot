#!/bin/sh
# Legt den Live-Benutzer SELBST an — die Standard-Komponente 0030-user-setup
# verlangt fest UID 1000, die auf System-Schnappschuessen immer besetzt ist
# (Original-Benutzer!) und scheitert dann still. Wir nehmen die naechste freie.
# Laeuft VOR 0030/0040, damit sudo/lightdm den Benutzer vorfinden.
# 2026-07-06 fuer "Schnappschuss fuer Linux Mint" (Herausgeber: Gilbert Rikus)

LIVE_USER=$(grep -o 'username=[^ ]*' /proc/cmdline | head -1 | cut -d= -f2)
[ -n "$LIVE_USER" ] || exit 0

if ! grep -q "^${LIVE_USER}:" /etc/passwd; then
    useradd -m -k /etc/skel -s /bin/bash -c "Live-Benutzer" "$LIVE_USER"
    passwd -d "$LIVE_USER" >/dev/null 2>&1
    for G in sudo adm cdrom plugdev lpadmin dip video audio; do
        getent group "$G" >/dev/null 2>&1 && usermod -aG "$G" "$LIVE_USER" 2>/dev/null
    done
fi

# 2026-07-14 Fix Login-Schleife: Der Benutzer existiert schon (System-Klon), aber
# sein Home FEHLT (Schnappschuss OHNE Homeverzeichnis). Dann ist das Passwort zwar
# korrekt, aber ohne Home startet die Sitzung nicht -> zurueck zum Login (Loop).
# Darum: fehlt das Home, ein frisches aus /etc/skel anlegen (richtige Besitzrechte).
HOME_DIR=$(getent passwd "$LIVE_USER" | cut -d: -f6)
if [ -n "$HOME_DIR" ] && [ "$HOME_DIR" != "/" ] && [ ! -d "$HOME_DIR" ]; then
    mkdir -p "$HOME_DIR"
    cp -aT /etc/skel "$HOME_DIR" 2>/dev/null || true
    chown -R "$LIVE_USER":"$LIVE_USER" "$HOME_DIR" 2>/dev/null || true
    chmod 700 "$HOME_DIR" 2>/dev/null || true
fi
exit 0
